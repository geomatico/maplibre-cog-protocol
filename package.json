{
  "name": "@geomatico/maplibre-cog-protocol",
  "version": "0.8.0",
  "description": "Custom protocol to load Cloud Optimized GeoTIFFs (COG) in Maplibre GL JS",
  "scripts": {
    "watch:src": "rimraf dist && rollup -c rollup.config.mjs --environment DEV --watch",
    "watch:examples": "five-server",
    "watch": "concurrently --names 'SRC,EXAMPLES' --prefix-colors 'yellow,blue' --kill-others 'npm run watch:src' 'npm run watch:examples'",
    "lint": "biome check --write src/",
    "test": "npm run lint && vitest run --coverage",
    "build:umd": "rollup -c rollup.config.mjs",
    "build:esm": "tsc --outDir dist/esm",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist/types",
    "build": "rimraf dist && concurrently --names 'UMD,ESM,TYPES' 'npm run build:umd' 'npm run build:esm' 'npm run build:types'",
    "gh-publish": "rimraf examples/dist && npm run build && cp -r dist examples && gh-pages -d examples",
    "prepare": "husky"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "browser": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "author": "Geomatico <info@geomatico.es>",
  "dependencies": {
    "@mapbox/sphericalmercator": "^2.0.2",
    "d3-scale": "^4.0.2",
    "geotiff": "^3.0.5",
    "quick-lru": "^7.1.0"
  },
  "peerDependencies": {
    "maplibre-gl": "^4.5.0 || ^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/d3-scale": "^4.0.8",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^10.0.0",
    "five-server": "^0.4.5",
    "gh-pages": "^6.1.1",
    "husky": "^9.1.7",
    "rimraf": "^6.0.1",
    "rollup": "^4.27.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
